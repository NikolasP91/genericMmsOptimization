{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MMS Optimization Input",
  "type": "object",
  "required": [
    "Cost_parameters",
    "Other_coefficients",
    "constraints",
    "optimization_parameters",
    "Generating_Units",
    "Time_granularity",
    "Load_forecast"
  ],
  "properties": {
    "run_mode": {
      "enum": ["RDAS", "DS"],
      "description": "Scheduling mode. RTD is intentionally unsupported in this project."
    },
    "Cost_parameters": { "type": "object" },
    "Other_coefficients": { "type": "object" },
    "constraints": { "type": "object" },
    "optimization_parameters": {
      "type": "object",
      "properties": {
        "solver": { "enum": ["highs", "cbc"] },
        "require_optimal": { "type": "boolean" },
        "big_m": {
          "oneOf": [
            { "const": "auto" },
            { "type": "number", "exclusiveMinimum": 0 }
          ]
        },
        "cost_curve_time_unit": {
          "enum": [
            "euro_per_mw_per_minute",
            "euro_per_mwh",
            "euro_per_dispatch_period"
          ],
          "description": "Unit convention for thermal PWL cost-curve coefficients."
        },
        "cost_curve_time_multiplier": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Optional explicit multiplier overriding cost_curve_time_unit."
        },
        "early_stopping": {
          "type": "object",
          "properties": {
            "time_limit": {
              "oneOf": [
                { "type": "null" },
                { "type": "number", "exclusiveMinimum": 0 }
              ]
            }
          }
        }
      }
    },
    "Generating_Units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "gen_id",
          "comments",
          "state",
          "current_Power(MW)",
          "availability",
          "Production_Forecast",
          "max_power(MW)",
          "min_power(MW)",
          "operating-states",
          "operating-state-transitions"
        ],
        "properties": {
          "var_gen_cost(euro/MW)": {
            "type": "array",
            "prefixItems": [
              {
                "type": "array",
                "minItems": 2,
                "items": { "type": "number" },
                "description": "Strictly increasing PWL breakpoints in MW for thermal units."
              },
              {
                "type": "array",
                "minItems": 2,
                "items": { "type": "number", "minimum": 0 },
                "description": "Base cost at first breakpoint followed by marginal segment costs."
              }
            ],
            "minItems": 2,
            "maxItems": 2
          }
        }
      }
    },
    "Time_granularity": { "type": "number", "exclusiveMinimum": 0 },
    "Load_forecast": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "number", "minimum": 0 }
    }
  }
}
